# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=*

# ── Database ──────────────────────────────────────────────────────────────────
# Leave DB_HOST empty → SQLite is used automatically (zero setup)
# Set DB_HOST to use PostgreSQL instead
# DB_HOST=localhost
# DB_NAME=kpos
# DB_USER=kpos
# DB_PASSWORD=kpos
# DB_PORT=5432

# ── AI assistant (optional) ───────────────────────────────────────────────────
CLAUDE_API_KEY=your-anthropic-api-key

# ── Azure AD (only needed for production SSO) ─────────────────────────────────
# ADFS_TENANT_ID=
# ADFS_CLIENT_ID=
# ADFS_CLIENT_SECRET=
